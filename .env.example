# Frontend public configuration example
# Values with VITE_ prefix are embedded into the browser bundle.

VITE_SITE_URL=https://forpeople.com.ua
VITE_API_URL=https://cms.forpeople.com.ua
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=public_xxxxxxxxxxxxxxxxx
VITE_EMAIL_TO=clinic@example.com
VITE_GOOGLE_MAPS_KEY=google_maps_browser_key_with_http_referrer_restrictions

# Optional image CDN delivery via ImageKit.
# Configure separate endpoints if Strapi uploads and site /public/images are served
# from different origins in ImageKit.
VITE_IMAGEKIT_MEDIA_URL_ENDPOINT=https://ik.imagekit.io/your_media_id
VITE_IMAGEKIT_SITE_URL_ENDPOINT=https://ik.imagekit.io/your_site_id

# Optional local app settings
# Optional: override Vite dev proxy target for `/api` and `/uploads`.
# Example for local Strapi development:
# VITE_API_PROXY_TARGET=http://localhost:1337
STRAPI_DISABLE_GUIDED_TOUR=true
