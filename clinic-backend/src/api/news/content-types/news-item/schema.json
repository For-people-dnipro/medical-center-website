{
  "kind": "collectionType",
  "collectionName": "news_items",
  "info": {
    "singularName": "news-item",
    "pluralName": "news",
    "displayName": "News"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "short_description": {
      "type": "text"
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "news.text-block",
        "news.image-block",
        "news.highlight-block",
        "news.quote-block"
      ]
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "theme": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::theme.theme"
    },
    "published_date": {
      "type": "date"
    },
    "seo_title": {
      "type": "string"
    },
    "seo_description": {
      "type": "text"
    }
  }
}
