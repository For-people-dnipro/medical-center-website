{
  "kind": "collectionType",
  "collectionName": "doctors",
  "info": {
    "singularName": "doctor",
    "pluralName": "doctors",
    "displayName": "Doctor"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "fullName": {
      "type": "string",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        },
        "content-type-builder": {
          "visible": false
        }
      }
    },
    "name": {
      "type": "string",
      "required": true
    },
    "surname": {
      "type": "string",
      "required": true
    },
    "position": {
      "type": "string",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        },
        "content-type-builder": {
          "visible": false
        }
      }
    },
    "positionShort": {
      "type": "string"
    },
    "positionLong": {
      "type": "string",
      "required": true
    },
    "specialisations": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::specialisation.specialisation"
    },
    "branch": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::branch.branch"
    },
    "experience": {
      "type": "integer",
      "required": true
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "slug": {
      "type": "uid",
      "required": true,
      "targetField": "fullName"
    },
    "order": {
      "type": "integer",
      "required": true
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "show_on_homepage": {
      "type": "boolean",
      "required": false
    },
    "homepage_priority": {
      "type": "integer"
    },
    "shortDescription": {
      "type": "text",
      "pluginOptions": {
        "content-manager": {
          "visible": false
        },
        "content-type-builder": {
          "visible": false
        }
      }
    },
    "fullDescription": {
      "type": "blocks"
    },
    "education": {
      "type": "blocks"
    },
    "experienceSection": {
      "type": "blocks"
    },
    "services": {
      "type": "blocks"
    },
    "quote": {
      "type": "text"
    },
    "button1_link": {
      "type": "string"
    },
    "button2_link": {
      "type": "string"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
